rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // We allow public reads temporarily to fix the admin dashboard 
    // because admin login uses a mock 'sessionStorage' flow instead of a real Firebase account.
    // In a fully secured app, admins would need actual Firebase Auth accounts.
    match /eventRegistrations/{document=**} {
      allow create: if true; 
      allow read, update, delete: if true;
    }
    
    match /boothBookings/{document=**} {
      allow create: if true;
      allow read, update, delete: if true;
    }
    
    match /chats/{document=**} {
      allow read, write: if true;
    }
    
    match /chatMessages/{document=**} {
      allow read, write: if true;
    }
    
    match /loginAttempts/{document=**} {
      allow read, write: if true;
    }
    
    match /users/{document=**} {
      allow read, write: if true;
    }

  }
}
